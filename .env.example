# Required
CLAUDE_API_KEY=sk-ant-...        # For summarization - https://console.anthropic.com/
EMBEDDING_API_KEY=...            # For embeddings (required if using openai or voyage)

# Optional with defaults
BP_DB_PATH=./data/biggerpockets.db
BP_SCRAPE_RATE=0.3               # requests per second (0.1 - 1.0)
BP_EMBEDDING_PROVIDER=openai     # openai | voyage | local
